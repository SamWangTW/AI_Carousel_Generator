# Copy this file to .env and fill in your values before running the backend.
# Never commit .env to version control.

# OpenAI API key — required for all AI pipeline stages
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model to use
# Recommended: gpt-4o (best quality) | gpt-4o-mini (faster, cheaper)
OPENAI_MODEL=gpt-4o

# Local output directory for generated slide images (relative to backend/)
OUTPUT_DIR=output

# Path to a Netscape-format cookies.txt file exported from your browser.
# Required when YouTube blocks transcript requests (bot detection).
# Export using a browser extension like "Get cookies.txt LOCALLY" (Chrome/Firefox).
# YOUTUBE_COOKIES_FILE=backend/cookies.txt

# --- Production only (not required for prototype) ---

# Google Cloud project ID (Cloud Run / Firestore / GCS)
# GCP_PROJECT_ID=your-gcp-project-id

# Google Cloud Storage bucket name for slide image uploads
# GCS_BUCKET_NAME=your-gcs-bucket-name
